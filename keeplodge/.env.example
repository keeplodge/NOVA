# KeepLodge Agent Environment Variables
# Copy to .env and fill in real values

# Anthropic (lead_agent + content_agent)
ANTHROPIC_API_KEY=sk-ant-...

# Facebook (lead_agent) — requires approved Graph API app
FACEBOOK_ACCESS_TOKEN=

# Netlify (waitlist_agent)
NETLIFY_TOKEN=
NETLIFY_SITE_ID=
NETLIFY_FORM_NAME=keeplodge-waitlist

# MailerLite (waitlist_agent)
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=
